.{
    .name = .zttp,
    .version = "0.18.0",
    .fingerprint = 0x6d6892a6f6d0b5fe, // Changing this has security and trust implications.
    .minimum_zig_version = "0.16.0",
    .dependencies = .{
        .zts = .{
            .path = "packages/zts",
        },
        .zttp_tools = .{
            .path = "packages/tools",
        },
        .zttp_runtime = .{
            .path = "packages/runtime",
        },
        .zttp_sdk = .{
            .path = "packages/zttp-sdk",
        },
        .zttp_modules = .{
            .path = "packages/modules",
        },
        .zttp_pi = .{
            .path = "packages/pi",
        },
        .zttp_proof_review = .{
            .path = "packages/proof-review",
        },
    },
    .paths = .{
        "README.md",
        "CHANGELOG.md",
        "CONTRIBUTING.md",
        "LICENSE",
        "RELEASE_CHECKLIST.md",
        "SECURITY.md",
        "build.zig",
        "build.zig.zon",
        "docs",
        "examples",
        "install.sh",
        "packages",
        "policy-hash.txt",
        "scripts",
        "tests",
        "zts_main.zig",
    },
}
