{"sse": "event: content_block_delta\ndata: {\"type\":\"content_block_delta\",\"index\":1,\"delta\":{\"type\":\"input_json_delta\",\"partial_json\":\"{\\\"file\\\": \\\"handler.ts\\\", \\\"content\\\": \\\"// WebSocket echo handler\\\\n// Upgrades HTTP connections to WebSocket and echoes every inbound\\\\n// message back to the sender.\\\\n\\\\nimport { send, close } from \\\\\\\"zttp:websocket\\\\\\\";\\\\nimport { logInfo } from \\\\\\\"zttp:log\\\\\\\";\\\\n\\\\n// HTTP upgrade entry-point: return 101 to accept the handshake.\\\\n// Spec<...> is narrowed to the properties the compiler can prove;\\\\n// fault_covered is omitted because the upgrade path has no fallible I/O.\\\\nfunction handler(req: Request): Response & Spec<\\\\n    | \\\\\\\"deterministic\\\\\\\"\\\\n    | \\\\\\\"read_only\\\\\\\"\\\\n    | \\\\\\\"retry_safe\\\\\\\"\\\\n    | \\\\\\\"idempotent\\\\\\\"\\\\n    | \\\\\\\"state_isolated\\\\\\\"\\\\n    | \\\\\\\"no_secret_leakage\\\\\\\"\\\\n    | \\\\\\\"no_credential_leakage\\\\\\\"\\\\n    | \\\\\\\"injection_safe\\\\\\\"\\\\n> {\\\\n    return Response.json({ upgraded: true }, { status: 101 });\\\\n}\\\\n\\\\n// Called once for each client that successfully connects.\\\\nexport function onOpen(ws: object, room: string): undefined {\\\\n    logInfo(\\\\\\\"ws:open\\\\\\\", { room });\\\\n}\\\\n\\\\n// Called for every inbound text frame.  Echo the data straight back.\\\\nexport function onMessage(ws: object, data: string, room: string): undefined {\\\\n    logInfo(\\\\\\\"ws:message\\\\\\\", { room });\\\\n    send(ws, data);\\\\n}\\\\n\\\\n// Called when a client disconnects (normal or abnormal closure).\\\\nexport function onClose(ws: object, code: number, reason: string, room: string): undefined {\\\\n    logInfo(\\\\\\\"ws:close\\\\\\\", { room, code });\\\\n}\\\\n\\\"}\"}}\n\n"}
