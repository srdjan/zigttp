{
  "permissions": {
    "allow": [
      "Bash(zigts expert *)",
      "Bash(zigts check *)",
      "Bash(zigts edit-simulate *)",
      "Bash(zigts describe-rule *)",
      "Bash(zigts search *)",
      "Bash(zigts agent init *)",
      "Bash(zigttp agent init *)"
    ],
    "deny": [
      "Bash(python3 *)",
      "Bash(python *)",
      "Edit(./.claude/hooks/**)",
      "Write(./.claude/hooks/**)",
      "Edit(./.claude/settings.json)",
      "Write(./.claude/settings.json)",
      "Edit(./packages/zigts/src/rule_registry.zig)",
      "Write(./packages/zigts/src/rule_registry.zig)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit-zts.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit-zig-module.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-zts.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-zig-module.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
